# IPX800 v3 to MQTT Bridge - Configuration Example
# Copy this file to .env and fill in your values

# IPX800 Connection
IPX800_HOST=192.168.1.12
IPX800_PORT=80
IPX800_USERNAME=your_ipx800_user
IPX800_PASSWORD=your_ipx800_password

# External MQTT Broker (required - not included)
# Examples: HomeAssistant MQTT addon, standalone Mosquitto, etc.
MQTT_BROKER_HOST=192.168.1.24
MQTT_BROKER_PORT=1883
MQTT_USERNAME=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password

# Optional Settings
MQTT_TOPIC_PREFIX=ipx800
HTTP_PORT=8080
POLLING_INTERVAL=30
LOG_LEVEL=INFO
